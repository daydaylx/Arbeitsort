<?xml version="1.0" encoding="utf-8"?>
<!--
    MontageZeit ist offline-only und sichert keine Daten in die Cloud.
    Alle Domains werden explizit ausgeschlossen.
-->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="false">
        <exclude domain="root" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="file" />
        <exclude domain="cache" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="file" />
        <exclude domain="cache" />
    </device-transfer>
</data-extraction-rules>
