{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Android: Build Debug APK",
      "type": "shell",
      "command": "./gradlew :app:assembleDebug",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Android: Install Debug APK",
      "type": "shell",
      "command": "./gradlew :app:installDebug",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Android: Launch App",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "DEVICE=\"$(./scripts/resolve_android_device.sh)\" && adb -s \"$DEVICE\" shell am start -n de.montagezeit.app/de.montagezeit.app.MainActivity"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Android: View Logcat",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "DEVICE=\"$(./scripts/resolve_android_device.sh)\" && PID=$(adb -s \"$DEVICE\" shell pidof de.montagezeit.app 2>/dev/null) && if [ -n \"$PID\" ]; then adb -s \"$DEVICE\" logcat --pid=\"$PID\" -v time; else adb -s \"$DEVICE\" logcat -v time | grep montagezeit; fi"
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Android: Clear App Data",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "DEVICE=\"$(./scripts/resolve_android_device.sh)\" && adb -s \"$DEVICE\" shell pm clear de.montagezeit.app"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Android: Full Debug Run",
      "type": "shell",
      "command": "./scripts/android_debug_run.sh",
      "isBackground": false,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "Android: Device List",
      "type": "shell",
      "command": "adb devices -l",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    }
  ]
}
